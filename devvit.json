{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "verdictlog",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Log Verdict",
        "description": "Record why this moderation action was taken",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/log-verdict"
      },
      {
        "label": "Log Verdict",
        "description": "Record why this moderation action was taken",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/log-verdict"
      },
      {
        "label": "VerdictLog — Search User",
        "description": "Search a user's moderation case file",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-search"
      },
      {
        "label": "VerdictLog — Configure Rules",
        "description": "Configure subreddit rules for verdicts",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-rules"
      },
      {
        "label": "VerdictLog — Retention Settings",
        "description": "Configure how long verdict data is retained",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-settings"
      }
    ]
  },
  "forms": {
    "logVerdictForm": "/internal/form/log-verdict-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "verdictlog_dev"
  }
}
